# Скопируйте в .env для локального запуска (не коммитьте .env)

# Строка подключения Neon / Supabase / Railway
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Секрет для токенов входа (та же строка, что на Render)
AUTH_SECRET=замените-на-длинную-случайную-строку

# Cloudflare Turnstile (Secret Key — только на сервере)
TURNSTILE_SECRET_KEY=

# --- Почта на Render (рекомендуется) ---
# Render блокирует Gmail SMTP (587/465). Используйте Resend (HTTPS API):
# 1) https://resend.com → API Keys → создать ключ
# 2) Добавить на Render: RESEND_API_KEY=re_...
# 3) Для теста: MAIL_FROM=Bunker <onboarding@resend.dev>
#    Не задавайте только <email@...> в угловых скобках — нужен формат выше или просто email@...
#    (письма только на email аккаунта Resend, пока не подключите свой домен)
RESEND_API_KEY=

# --- Почта локально (опционально, Gmail App Password) ---
SMTP_USER=tusa.team.service@gmail.com
SMTP_PASS=ваш-пароль-приложения-gmail
MAIL_FROM=Bunker <tusa.team.service@gmail.com>

# Локально CORS обычно не нужен
# CORS_ORIGIN=http://localhost:3000

PORT=3000
